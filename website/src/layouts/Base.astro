---
import TopBar from '../components/TopBar.astro';
interface Props {
  title?: string;
  hideFooter?: boolean;
  frontmatter?: { title?: string };
}
const { title, hideFooter = false, frontmatter } = Astro.props;
const pageTitle = title ?? frontmatter?.title ?? 'abrasive';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Caveat:wght@400;500;600;700&family=Figtree:wght@400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Caveat:wght@400;500;600;700&family=Figtree:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <title>{pageTitle}</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      :root {
        --bg: #161c24;
        --fg: #c9d1d9;
        --muted: #8b949e;
        --accent: #e8b931;
        --code-bg: #0f1319;
        --border: #30363d;
      }
      html {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
        background: var(--bg);
        color: var(--fg);
        overflow-x: clip;
      }
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        padding: 0;
      }
      .page-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 0 2rem;
        width: 100%;
      }
      footer {
        margin-top: auto;
        width: 100vw;
        background: #090c10;
        border-top: 1px solid var(--border);
        padding: 1.25rem 2rem;
        display: flex;
        justify-content: center;
      }
      .footer-row {
        display: flex;
        align-items: center;
        gap: 2rem;
        width: 100%;
        max-width: 1200px;
        font-size: 0.85rem;
        flex-wrap: wrap;
      }
      .footer-links {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
      }
      .footer-links a {
        color: var(--muted);
        text-decoration: none;
        transition: color 0.15s;
      }
      .footer-links a:hover {
        color: var(--fg);
      }
      .footer-copy {
        margin-left: auto;
        color: var(--muted);
        font-size: 0.75rem;
      }
    </style>
  </head>
  <body>
    <TopBar />
    <slot name="top-banner" />
    <div class="page-body">
      <slot />
    </div>
    {!hideFooter && (
      <footer>
        <div class="footer-row">
          <nav class="footer-links">
            <a href="/">Home</a>
            <a href="/#demo">Demo</a>
            <a href="https://github.com/Clavigers/abrasive">GitHub</a>
            <a href="/tos">TOS</a>
            <a href="/privacy">Privacy Policy</a>
          </nav>
          <span class="footer-copy">&copy; 2026 Claviger.</span>
        </div>
      </footer>
    )}
  </body>
</html>
