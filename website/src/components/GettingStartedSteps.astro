---
import { Content } from '../content/getting-started.mdx';
---
<section class="gs-steps" id="get-started">
  <Content />
</section>

<style>
  .gs-steps {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 576px;
    width: 100%;
    align-items: flex-start;
    margin: 3rem auto 0;
  }
  .gs-steps :global(.code-block) {
    margin: 0.5rem 0;
  }
  .gs-steps :global(.code-block:hover) {
    border-color: var(--muted);
  }
  .gs-steps :global(.code-block code) {
    color: var(--muted);
    transition: color 0.15s;
  }
  .gs-steps :global(.code-block:hover code) {
    color: #fff;
  }
  .gs-steps :global(.code-block + .code-block) {
    margin-top: -0.75rem;
  }
  .gs-steps :global(p) {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }
  .gs-steps :global(p code) {
    color: var(--accent);
    background: var(--code-bg);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
    font-size: 0.85em;
  }
</style>
