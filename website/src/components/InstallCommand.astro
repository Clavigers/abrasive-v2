---
import CodeBlock from './CodeBlock.astro';
interface Props {
  showMoreMethods?: boolean;
  large?: boolean;
}
const { showMoreMethods = true, large = false } = Astro.props;
---
<div class:list={['install', { large }]}>
  <p class="label">Install</p>
  <div class="install-inner">
    <CodeBlock code="cargo install abrasive" />
    {showMoreMethods && (
      <a href="/get_abrasive" class="more-methods">More installation methods</a>
    )}
  </div>
</div>

<style>
  .label {
    color: var(--muted);
    font-family: "IBM Plex Mono", "SFMono-Regular", Consolas, monospace;
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }
  .install-inner {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .more-methods {
    display: inline-block;
    margin-top: 0.4rem;
    color: #58a6ff;
    font-size: 0.8rem;
    text-decoration: underline;
    transition: color 0.15s;
  }
  .more-methods:hover {
    color: #80b9ff;
  }

  .install.large .label {
    font-size: 1.2625rem;
    margin-bottom: 0.425rem;
  }
  .install.large :global(.code-block) {
    font-size: 1.05rem;
    padding: 0.94rem 1.25rem;
    gap: 0.94rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.15s, background 0.15s;
  }
  .install.large :global(.code-block:hover) {
    transform: translateY(-1px);
    box-shadow: 0 3px 12px rgba(232, 185, 49, 0.12);
  }
  .install.large :global(.code-block svg) {
    width: 20px;
    height: 20px;
  }
  .install.large .more-methods {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  @media (max-width: 880px) {
    .install.large .label {
      color: var(--muted);
      position: relative;
      z-index: 2;
    }
    .install.large :global(.code-block) {
      position: relative;
      z-index: 1;
      box-shadow: 0 0 28px 6px var(--bg);
    }
  }
</style>
