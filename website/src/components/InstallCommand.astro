---
import CodeBlock from './CodeBlock.astro';
interface Props {
  showMoreMethods?: boolean;
  large?: boolean;
}
const { showMoreMethods = true, large = false } = Astro.props;
---
<div class:list={['install', { large }]}>
  <div class="install-inner">
    <CodeBlock code="cargo install abrasive" />
    {showMoreMethods && (
      <a href="/get_abrasive" class="more-methods">More installation methods</a>
    )}
  </div>
</div>

<style>
  .install-inner {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .more-methods {
    display: inline-block;
    margin-top: 0.4rem;
    color: #58a6ff;
    font-size: 0.8rem;
    text-decoration: underline;
    transition: color 0.15s;
  }
  .more-methods:hover {
    color: #80b9ff;
  }

  .install.large :global(.code-block) {
    font-size: 1.05rem;
    padding: 0.94rem 1.25rem;
    gap: 0.94rem;
    border-color: var(--muted);
    background: #131821;
    transition: none;
  }
  .install.large :global(.code-block:hover) {
    border-color: var(--muted);
    background: #131821;
  }
  .install.large :global(.code-block svg) {
    width: 20px;
    height: 20px;
  }
  .install.large .more-methods {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  @media (max-width: 880px) {
    .install.large :global(.code-block) {
      position: relative;
      z-index: 1;
      box-shadow: 0 0 28px 6px var(--bg);
    }
  }
</style>
