---
interface Props {
  code: string;
  accent?: string;
}
const { code, accent } = Astro.props;
const accentStyle = accent ? `color: ${accent}` : undefined;
---
<button class="code-block" data-cmd={code} aria-label={`Copy: ${code}`}>
  <code style={accentStyle}>{code}</code>
  <span class="copy-icon" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
      <path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 010 1.5h-1.5a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-1.5a.75.75 0 011.5 0v1.5A1.75 1.75 0 019.25 16h-7.5A1.75 1.75 0 010 14.25z"/>
      <path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0114.25 11h-7.5A1.75 1.75 0 015 9.25zm1.75-.25a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-7.5a.25.25 0 00-.25-.25z"/>
    </svg>
  </span>
</button>

<style is:global>
  .copy-toast {
    position: fixed;
    left: 50%;
    bottom: 2rem;
    transform: translate(-50%, 1rem);
    background: #0f1319;
    color: #3fb950;
    border: 1px solid #30363d;
    border-radius: 8px;
    padding: 0.7rem 1.2rem;
    font-size: 0.9rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
    z-index: 1000;
  }
  .copy-toast.visible {
    opacity: 1;
    transform: translate(-50%, 0);
  }
</style>

<style>
  .code-block {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
    font-size: 0.9rem;
    white-space: nowrap;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    text-align: left;
  }
  .code-block:hover {
    border-color: var(--accent);
  }
  .code-block:active {
    background: #161c24;
  }
  code {
    color: #fff;
    white-space: nowrap;
  }
  .copy-icon {
    color: var(--muted);
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .code-block:hover .copy-icon {
    color: var(--fg);
  }
</style>

<script>
  const copyIcon = '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 010 1.5h-1.5a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-1.5a.75.75 0 011.5 0v1.5A1.75 1.75 0 019.25 16h-7.5A1.75 1.75 0 010 14.25z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0114.25 11h-7.5A1.75 1.75 0 015 9.25zm1.75-.25a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-7.5a.25.25 0 00-.25-.25z"/></svg>';
  const checkIcon = '<svg width="16" height="16" viewBox="0 0 16 16" fill="#3fb950"><path d="M13.78 4.22a.75.75 0 010 1.06l-7.25 7.25a.75.75 0 01-1.06 0L2.22 9.28a.75.75 0 011.06-1.06L6 10.94l6.72-6.72a.75.75 0 011.06 0z"/></svg>';

  let toast: HTMLDivElement | null = null;
  let toastTimer: number | undefined;
  function showToast(message: string) {
    if (!toast) {
      toast = document.createElement('div');
      toast.className = 'copy-toast';
      document.body.appendChild(toast);
    }
    toast.textContent = message;
    requestAnimationFrame(() => toast!.classList.add('visible'));
    clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => toast!.classList.remove('visible'), 1500);
  }

  document.querySelectorAll<HTMLButtonElement>('.code-block').forEach((block) => {
    block.addEventListener('click', () => {
      const cmd = block.getAttribute('data-cmd')!;
      navigator.clipboard.writeText(cmd);
      const icon = block.querySelector('.copy-icon')!;
      icon.innerHTML = checkIcon;
      setTimeout(() => { icon.innerHTML = copyIcon; }, 2000);
      showToast('Copied to clipboard!');
    });
  });
</script>
