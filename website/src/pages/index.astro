---
import Base from '../layouts/Base.astro';
import InstallCommand from '../components/InstallCommand.astro';
import PaperNote from '../components/PaperNote.astro';
import GettingStartedSteps from '../components/GettingStartedSteps.astro';
import { Content as Hero } from '../content/hero.md';
import { Content as Warning } from '../content/warning.md';
import { Content as PrealphaIntro } from '../content/prealpha-intro.md';
import { Content as PrealphaCaption } from '../content/prealpha-caption.md';
import { Content as PrealphaFull } from '../content/prealpha-full.md';
---
<Base title="abrasive">
  <main>
    <div class="hero">
      <div class="cta">
        <InstallCommand large showMoreMethods={false} />
      </div>
      <div class="hero-description">
        <Hero />
      </div>
      <div class="hero-warning">
        <PaperNote>
          <Warning />
        </PaperNote>
      </div>
    </div>

    <GettingStartedSteps />

    <section class="prealpha-gate">
      <PrealphaIntro />
      <div class="prealpha-bar">
        <div class="prealpha-fill" style="width: 15%"></div>
      </div>
      <PrealphaCaption />
      <a class="prealpha-cta" data-auth="signed-out" href="/dashboard/sign-up">Sign up free</a>
      <PrealphaFull />
    </section>

  </main>
</Base>

<script>
  import { createClient } from '@supabase/supabase-js';

  const url = import.meta.env.PUBLIC_SUPABASE_URL;
  const anonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  if (url && anonKey) {
    const supabase = createClient(url, anonKey);
    const gate = document.querySelector<HTMLElement>('.prealpha-gate');
    const currentEl = gate?.querySelector<HTMLElement>('.prealpha-current');
    const capEls = gate?.querySelectorAll<HTMLElement>('.prealpha-cap');
    const fillEl = gate?.querySelector<HTMLElement>('.prealpha-fill');
    const ctaEl = gate?.querySelector<HTMLElement>('.prealpha-cta');
    const fullEl = gate?.querySelector<HTMLElement>('.prealpha-full');

    const render = (count: number, cap: number) => {
      if (!gate) return;
      if (currentEl) currentEl.textContent = String(count);
      capEls?.forEach((el) => (el.textContent = String(cap)));
      if (fillEl) fillEl.style.width = `${Math.min(100, (count / cap) * 100)}%`;
      if (count >= cap) {
        if (ctaEl) ctaEl.hidden = true;
        if (fullEl) fullEl.hidden = false;
      } else {
        if (ctaEl) ctaEl.hidden = false;
        if (fullEl) fullEl.hidden = true;
      }
    };

    // Prefer signup_status (returns {count, cap}); fall back to user_count + hardcoded cap if not deployed yet.
    supabase.rpc('signup_status').then(({ data, error }) => {
      if (!error && data) {
        const count = Math.max(0, Number((data as { count?: unknown }).count ?? 0));
        const cap = Math.max(1, Number((data as { cap?: unknown }).cap ?? 20));
        render(count, cap);
        return;
      }
      supabase.rpc('user_count').then(({ data: countData, error: countErr }) => {
        if (countErr || typeof countData !== 'number') return;
        render(Math.max(0, countData), 20);
      });
    });
  }
</script>

<style>
  .prealpha-gate {
    width: min(100%, 720px);
    margin: 3.5rem auto 8rem;
    padding: 0 2rem;
    text-align: center;
    font-family: "Figtree", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    letter-spacing: -0.025em;
  }
  .prealpha-gate :global(.prealpha-note) {
    font-size: clamp(0.78rem, 2.1vw, 1.35rem);
    color: var(--fg);
    line-height: 1.45;
    font-weight: 400;
    max-width: 900px;
    margin: 0 auto 0.9rem;
  }
  .prealpha-bar {
    width: 100%;
    max-width: 360px;
    height: 4px;
    margin: 0 auto;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    overflow: hidden;
  }
  .prealpha-fill {
    height: 100%;
    background: linear-gradient(90deg, #e8b931, #d4872e);
    border-radius: 2px;
    transition: width 0.4s ease;
  }
  .prealpha-gate :global(.prealpha-caption) {
    font-size: clamp(0.78rem, 2.1vw, 1.35rem);
    color: var(--fg);
    line-height: 1.45;
    font-weight: 400;
    margin-top: 0.6rem;
  }
  .prealpha-gate :global(.prealpha-current) {
    font-weight: inherit;
  }
  .prealpha-cta {
    display: inline-block;
    margin-top: 1.5rem;
    background: rgb(11, 138, 15);
    color: #fff;
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: -0.0175em;
    padding: 0.6rem 1.25rem;
    border-radius: 0.25em;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .prealpha-cta:hover,
  .prealpha-cta:focus {
    background: rgb(60, 175, 55);
    color: #fff;
  }
  .prealpha-cta[hidden] {
    display: none;
  }
  .prealpha-gate :global(.prealpha-full) {
    margin-top: 1rem;
    font-size: 0.95rem;
    color: var(--muted);
  }
  .prealpha-gate :global(.prealpha-full[hidden]) {
    display: none;
  }
  .hero-warning {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: 0.5rem;
  }
  main {
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    width: 100%;
    min-height: calc(100svh - var(--topbar-h, 57px) - 160px);
    padding: 4rem 0 2rem;
    position: relative;
  }
  .hero-description {
    font-family: "Figtree", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: clamp(0.62rem, 1.68vw, 1.08rem);
    color: var(--muted);
    text-align: left;
    letter-spacing: -0.01em;
    margin: 20px 0 0;
    line-height: 1.55;
    max-width: 576px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.85em;
  }
  .hero-description :global(p) {
    margin: 0;
  }
  .hero-description :global(strong) {
    color: var(--fg);
    font-weight: 600;
  }
  .hero-description :global(code) {
    font-family: "IBM Plex Mono", "SFMono-Regular", Consolas, monospace;
    font-size: 0.88em;
    background: var(--code-bg);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    color: var(--accent);
  }
  .cta {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    margin-top: 0.5rem;
  }
  @media (max-width: 880px) {
    main {
      padding-top: 0;
    }
    .hero {
      padding: 1rem 0;
    }
  }
</style>
