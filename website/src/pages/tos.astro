---
import Base from '../layouts/Base.astro';
---
<Base title="abrasive - terms of service">
  <main>
    <h1>Terms of Service</h1>
    <p>This page is a placeholder. Full Terms of Service coming soon.</p>
  </main>
</Base>

<style>
  main {
    width: min(100%, 720px);
    margin: 0 auto;
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--fg);
  }
  p {
    color: var(--fg);
    font-size: 1rem;
    line-height: 1.6;
  }
</style>
